{
  "name": "prettier-plugin-bootstrap",
  "version": "0.4.1",
  "description": "A Prettier plugin for automatic Bootstrap class sorting",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./sorter": {
      "types": "./dist/sorter.d.ts",
      "import": "./dist/sorter.mjs",
      "require": "./dist/sorter.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.19"
  },
  "keywords": [
    "prettier",
    "prettier-plugin",
    "plugin",
    "bootstrap",
    "bootstrap5",
    "bootstrap-5",
    "css",
    "class",
    "class-sorter",
    "class-order",
    "sorting",
    "sort-classes",
    "formatter",
    "html",
    "jsx",
    "react",
    "vue",
    "svelte",
    "astro",
    "angular"
  ],
  "author": {
    "name": "Pierluigi Lenoci",
    "url": "https://github.com/pierluigilenoci"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pierluigilenoci/prettier-plugin-bootstrap.git"
  },
  "bugs": {
    "url": "https://github.com/pierluigilenoci/prettier-plugin-bootstrap/issues"
  },
  "homepage": "https://github.com/pierluigilenoci/prettier-plugin-bootstrap#readme",
  "peerDependencies": {
    "prettier": "^3.0.0",
    "prettier-plugin-astro": ">=0.14.0",
    "prettier-plugin-svelte": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "prettier-plugin-astro": {
      "optional": true
    },
    "prettier-plugin-svelte": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^4.1.1",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "~7.3.5",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "build": "tsdown && tsc -p tsconfig.build.json",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "packageManager": "pnpm@10.34.3",
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.28.1"
    }
  }
}
