{
  "name": "prettier-plugin-bootstrap",
  "version": "0.3.2",
  "description": "A Prettier plugin for automatic Bootstrap class sorting",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./sorter": {
      "types": "./dist/sorter.d.ts",
      "import": "./dist/sorter.mjs",
      "require": "./dist/sorter.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "keywords": [
    "prettier",
    "plugin",
    "bootstrap",
    "css",
    "class",
    "sorting",
    "class-order",
    "formatter"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pierluigilenoci/prettier-plugin-bootstrap.git"
  },
  "bugs": {
    "url": "https://github.com/pierluigilenoci/prettier-plugin-bootstrap/issues"
  },
  "homepage": "https://github.com/pierluigilenoci/prettier-plugin-bootstrap#readme",
  "peerDependencies": {
    "prettier": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "~7.3.5",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "build": "tsdown && tsc -p tsconfig.build.json",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "packageManager": "pnpm@10.34.3",
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.28.1"
    }
  }
}
