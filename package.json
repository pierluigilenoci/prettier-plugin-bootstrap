{
  "name": "prettier-plugin-bootstrap",
  "version": "0.3.0",
  "description": "A Prettier plugin for automatic Bootstrap class sorting",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./sorter": {
      "types": "./dist/sorter.d.ts",
      "import": "./dist/sorter.mjs",
      "require": "./dist/sorter.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "prettier",
    "plugin",
    "bootstrap",
    "css",
    "class",
    "sorting",
    "class-order",
    "formatter"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pierluigilenoci/prettier-plugin-bootstrap.git"
  },
  "bugs": {
    "url": "https://github.com/pierluigilenoci/prettier-plugin-bootstrap/issues"
  },
  "homepage": "https://github.com/pierluigilenoci/prettier-plugin-bootstrap#readme",
  "peerDependencies": {
    "prettier": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.3.0",
    "prettier": "^3.5.0",
    "tsdown": "^0.21.10",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "build": "tsdown && tsc -p tsconfig.build.json",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "packageManager": "pnpm@10.33.0"
}
