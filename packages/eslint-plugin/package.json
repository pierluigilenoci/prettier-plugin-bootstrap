{
  "name": "eslint-plugin-bootstrap-order",
  "version": "0.1.0",
  "description": "ESLint plugin for Bootstrap class order validation — companion to prettier-plugin-bootstrap",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "keywords": [
    "eslint",
    "eslint-plugin",
    "bootstrap",
    "bootstrap5",
    "class-sorting",
    "class-order",
    "prettier-plugin-bootstrap"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pierluigilenoci/prettier-plugin-bootstrap.git",
    "directory": "packages/eslint-plugin"
  },
  "peerDependencies": {
    "eslint": ">=8.0.0",
    "prettier-plugin-bootstrap": "*"
  },
  "devDependencies": {
    "eslint": "*",
    "typescript": "*",
    "vitest": "*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  }
}
